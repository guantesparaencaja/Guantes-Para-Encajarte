rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isOwner(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }

    // ===============================================================
    // Rules for Collections
    // ===============================================================

    // Usuarios
    match /users/{uid} {
      allow read, update: if isOwner(uid) || isAdmin();
      allow create: if isAuthenticated();
      allow delete: if isAdmin();
    }

    // Entrenos / Videos de entrenamiento
    match /workout_videos/{id} {
      allow read: if isAuthenticated();
      allow create, update: if isAdmin();
      allow delete: if isAdmin();
    }
    
    match /workout_categories/{id} {
      allow read: if isAuthenticated();
      allow create, update: if isAdmin();
      allow delete: if isAdmin();
    }

    // Clases y reservas
    match /clases/{fecha}/reservas/{uid} {
      allow read: if isAuthenticated();
      allow create, update: if isOwner(uid) || isAdmin();
      allow delete: if isAdmin();
    }
    
    match /bookings/{id} {
      allow read: if isAuthenticated();
      allow create, update: if isOwner(request.resource.data.user_id) || isAdmin();
      allow delete: if isAdmin();
    }

    // Pagos
    match /payments/{id} {
      allow read: if isOwner(resource.data.user_id) || isAdmin();
      allow create, update: if isOwner(request.resource.data.user_id) || isAdmin();
      allow delete: if isAdmin();
    }

    // Planes
    match /planes/{id} {
      allow read: if isAuthenticated();
      allow write, delete: if isAdmin();
    }

    // Notificaciones
    match /notifications/{id} {
      allow read: if isOwner(resource.data.user_id) || resource.data.user_id == 'admin' || isAdmin();
      allow create: if isAuthenticated();
      allow update: if isOwner(resource.data.user_id) || isAdmin();
      allow delete: if isAdmin();
    }

    // Default rules for other collections
    match /{path=**} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && !isAdmin() && request.method != 'delete';
      allow write: if isAdmin();
    }
  }
}
