rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' || 
         (request.auth.token.email == "guantesparaencajar@gmail.com" && request.auth.token.email_verified == true));
    }

    // ===============================================================
    // Users Collection
    // ===============================================================
    match /users/{userId} {
      // Users can read their own profile, admins can read all
      allow read: if isOwner(userId) || isAdmin();
      
      // Allow creation during registration or by admin
      allow create: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      
      // Users can update their own data (except role unless admin)
      allow update: if (isOwner(userId) && (request.resource.data.role == resource.data.role || isAdmin())) || isAdmin();
      
      // Only admins can delete users
      allow delete: if isAdmin();
    }

    // ===============================================================
    // Meals Collection
    // ===============================================================
    match /meals/{mealId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && (request.resource.data.created_by == request.auth.uid || isAdmin());
      allow update: if isAuthenticated() && (resource.data.created_by == request.auth.uid || isAdmin());
      allow delete: if isAdmin() || (isAuthenticated() && resource.data.created_by == request.auth.uid);
    }

    // ===============================================================
    // Availabilities Collection
    // ===============================================================
    match /availabilities/{availabilityId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // ===============================================================
    // Bookings Collection
    // ===============================================================
    match /bookings/{bookingId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && (request.resource.data.user_id == request.auth.uid || isAdmin());
      allow update: if isAuthenticated() && (resource.data.user_id == request.auth.uid || isAdmin());
      allow delete: if isAdmin() || (isAuthenticated() && resource.data.user_id == request.auth.uid);
    }

    // ===============================================================
    // Classes Collection
    // ===============================================================
    match /classes/{classId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // ===============================================================
    // Community Posts
    // ===============================================================
    match /posts/{postId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.author_id == request.auth.uid;
      allow update, delete: if isAuthenticated() && (resource.data.author_id == request.auth.uid || isAdmin());
    }
    
    match /posts/{postId}/comments/{commentId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.author_id == request.auth.uid;
      allow update, delete: if isAuthenticated() && (resource.data.author_id == request.auth.uid || isAdmin());
    }

    // ===============================================================
    // Challenges Collection
    // ===============================================================
    match /challenges/{challengeId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // ===============================================================
    // Workout History & Achievements
    // ===============================================================
    match /workout_history/{docId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    match /user_achievements/{docId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    // ===============================================================
    // Mail Collection
    // ===============================================================
    match /mail/{mailId} {
      allow create: if isAuthenticated();
      allow read, update, delete: if isAdmin();
    }

    // ===============================================================
    // Global Settings
    // ===============================================================
    match /settings/{settingId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // ===============================================================
    // Workout Content
    // ===============================================================
    match /workout_categories/{catId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || (isAuthenticated() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'teacher');
    }

    match /workout_videos/{videoId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || (isAuthenticated() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'teacher');
    }

    // ===============================================================
    // Saberes (Combos & Tutorials)
    // ===============================================================
    match /combos/{comboId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /tutorials/{tutorialId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /combo_progress/{progressId} {
      allow read: if isAuthenticated() && (resource.data.user_id == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && request.resource.data.user_id == request.auth.uid;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ===============================================================
    // Notifications
    // ===============================================================
    match /notifications/{notificationId} {
      allow read: if isAuthenticated() && (resource.data.user_id == request.auth.uid || isAdmin());
      allow create: if isAuthenticated();
      allow update, delete: if isAdmin();
    }

    // ===============================================================
    // Custom Routines
    // ===============================================================
    match /custom_routines/{routineId} {
      allow read: if isAuthenticated() && (resource.data.user_id == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && request.resource.data.user_id == request.auth.uid;
      allow update, delete: if isAuthenticated() && (resource.data.user_id == request.auth.uid || isAdmin());
    }
  }
}
